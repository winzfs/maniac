{
  "name": "maniac-garage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "d1:migrate:initial:remote": "wrangler d1 execute maniac-garage-dev --remote --file migrations/0001_initial.sql",
    "d1:migrate:remote": "wrangler d1 execute maniac-garage-dev --remote --file migrations/0002_add_maintenance_logs_and_parts.sql",
    "d1:migrate:community:remote": "wrangler d1 execute maniac-garage-dev --remote --file migrations/0003_add_boards_posts_comments.sql",
    "d1:migrate:board-meta:remote": "wrangler d1 execute maniac-garage-dev --remote --file migrations/0004_add_board_metadata.sql",
    "d1:migrate:all:remote": "npm run d1:migrate:initial:remote && npm run d1:migrate:remote && npm run d1:migrate:community:remote && npm run d1:migrate:board-meta:remote",
    "d1:tables:remote": "wrangler d1 execute maniac-garage-dev --remote --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
    "pages:build": "next build",
    "pages:deploy": "npm run pages:build && wrangler pages deploy out --project-name maniac-garage",
    "pages:preview": "npm run pages:build && wrangler pages dev out",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "next": "15.3.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.2",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wrangler": "^4.18.0"
  }
}
